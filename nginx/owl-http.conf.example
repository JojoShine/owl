# Nginx 简单 HTTP 配置
# 用于非 HTTPS 环境（开发、测试）
# 使用方法：
# 1. 复制到 /etc/nginx/sites-available/ 或 /etc/nginx/conf.d/
# 2. 修改 server_name 为实际域名或 IP
# 3. 执行 nginx -t 检查语法
# 4. 执行 systemctl restart nginx 重载配置

upstream backend {
  server 127.0.0.1:3001;
}

upstream frontend {
  server 127.0.0.1:3000;
}

server {
  listen 80;
  server_name your-domain.com www.your-domain.com;

  access_log /var/log/nginx/owl-access.log;
  error_log /var/log/nginx/owl-error.log;

  client_max_body_size 100M;

  # WebSocket 支持（用于实时通知）
  location /owl/socket.io {
    proxy_pass http://backend;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # 长连接超时配置
    proxy_connect_timeout 60s;
    proxy_send_timeout 3600s;
    proxy_read_timeout 3600s;
    proxy_buffering off;

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # 公开 API 代理（对外提供接口给第三方系统调用）
  location /owl/api/public {
    proxy_pass http://backend;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    proxy_buffering off;

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # API 后端代理
  location /owl/api {
    proxy_pass http://backend;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    proxy_buffering off;

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # 静态文件/上传文件代理
  location /owl/uploads/ {
    proxy_pass http://backend/uploads/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # 静态文件缓存
    expires 1d;
    add_header Cache-Control "public, max-age=86400";

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # 前端应用代理（Next.js）
  location /owl {
    proxy_pass http://frontend;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_cache_bypass $http_upgrade;
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # 根路径重定向
  location = / {
    return 301 /owl;
  }

  # 禁用访问某些文件
  location ~ /\. {
    deny all;
  }

  # Gzip 压缩
  gzip on;
  gzip_vary on;
  gzip_min_length 1024;
  gzip_comp_level 6;
  gzip_types text/plain text/css text/xml text/javascript
             application/json application/javascript application/xml+rss
             application/rss+xml font/truetype font/opentype
             application/vnd.ms-fontobject image/svg+xml;
}

