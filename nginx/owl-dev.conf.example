# Nginx 本地开发配置示例
# 用于 macOS 本地开发时的反向代理配置
# 使用方法：
# 1. 复制到 /usr/local/etc/nginx/servers/ (macOS via Homebrew)
# 2. 执行 brew services restart nginx

upstream backend {
  server 127.0.0.1:3001;
}

upstream frontend {
  server 127.0.0.1:3000;
}

server {
  listen 80;
  server_name localhost 127.0.0.1;

  access_log /usr/local/var/log/nginx/owl-dev-access.log;
  error_log /usr/local/var/log/nginx/owl-dev-error.log;

  client_max_body_size 100M;

  # WebSocket 支持（用于实时通知）
  location /owl/socket.io {
    proxy_pass http://backend;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    proxy_connect_timeout 60s;
    proxy_send_timeout 3600s;
    proxy_read_timeout 3600s;
    proxy_buffering off;
  }

  # 公开 API 代理（对外提供接口给第三方系统调用）
  location /owl/api/public {
    proxy_pass http://backend;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    proxy_buffering off;
  }

  # API 后端代理
  location /owl/api {
    proxy_pass http://backend;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    proxy_buffering off;
  }

  # 前端应用代理（Next.js）
  location /owl {
    proxy_pass http://frontend;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_cache_bypass $http_upgrade;
  }

  # 根路径重定向
  location = / {
    return 301 /owl;
  }

  # 禁用访问某些文件
  location ~ /\. {
    deny all;
  }
}
