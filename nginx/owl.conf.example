# Nginx HTTPS 配置
# 用于生产环境（支持 SSL/TLS）
# 使用方法：
# 1. 复制到 /etc/nginx/sites-available/ 或 /etc/nginx/conf.d/
# 2. 修改 server_name 为实际域名
# 3. 配置 SSL 证书路径
# 4. 执行 nginx -t 检查语法
# 5. 执行 systemctl restart nginx 重载配置

upstream backend {
  server 127.0.0.1:3001;
}

upstream frontend {
  server 127.0.0.1:3000;
}

# HTTP 重定向至 HTTPS
server {
  listen 80;
  server_name your-domain.com www.your-domain.com;
  return 301 https://$server_name$request_uri;
}

# HTTPS 主配置
server {
  listen 443 ssl http2;
  server_name your-domain.com www.your-domain.com;

  # SSL 证书配置
  ssl_certificate /etc/ssl/certs/your-domain.crt;
  ssl_certificate_key /etc/ssl/private/your-domain.key;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_ciphers HIGH:!aNULL:!MD5;
  ssl_prefer_server_ciphers on;

  # 日志
  access_log /var/log/nginx/owl-access.log;
  error_log /var/log/nginx/owl-error.log;

  # 请求体大小限制
  client_max_body_size 100M;

  # WebSocket 支持（用于实时通知）
  location /owl/socket.io {
    proxy_pass http://backend/socket.io;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # 长连接超时配置
    proxy_connect_timeout 60s;
    proxy_send_timeout 3600s;
    proxy_read_timeout 3600s;
    proxy_buffering off;

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # 公开 API 代理（对外提供接口给第三方系统调用）
  location /owl/api/public {
    proxy_pass http://backend/api/public;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    proxy_buffering off;

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # API 后端代理
  location /owl/api {
    proxy_pass http://backend/api;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    proxy_buffering off;

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # 前端应用代理（Next.js）
  location /owl {
    proxy_pass http://frontend;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_cache_bypass $http_upgrade;
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # IP 白名单（可选）
    # allow 192.168.1.0/24;
    # allow 1.2.3.4;
    # deny all;
  }

  # 根路径重定向
  location = / {
    return 301 /owl;
  }

  # 禁用访问某些文件
  location ~ /\. {
    deny all;
  }

  # 静态资源缓存
  location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
    proxy_pass http://frontend;
    proxy_cache_valid 200 1y;
    proxy_cache_bypass $http_pragma $http_authorization;
    add_header Cache-Control "public, max-age=31536000, immutable";
  }

  # Gzip 压缩
  gzip on;
  gzip_vary on;
  gzip_min_length 1024;
  gzip_comp_level 6;
  gzip_types text/plain text/css text/xml text/javascript
             application/json application/javascript application/xml+rss
             application/rss+xml font/truetype font/opentype
             application/vnd.ms-fontobject image/svg+xml;
}
