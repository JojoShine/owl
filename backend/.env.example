# Server
NODE_ENV=development
PORT=6002

# Database (必选)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=admin_platform
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (可选 - 如未配置将使用内存存储)
# 用于验证码存储、缓存等功能
# 未配置时系统将自动使用内存存储作为备选方案
# Redis 6.0+ 支持用户名认证，如需使用可添加 REDIS_USERNAME 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# JWT (必选)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# Minio (必选)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=admin-platform

# CORS (必选)
CORS_ORIGIN=http://localhost:3000

# Application Path Prefix (可选 - 用于反向代理部署)
# 如果应用部署在子路径下（如 /owl），需要设置此值
# 例如：APP_PATH_PREFIX=/owl
# 留空表示部署在根路径
APP_PATH_PREFIX=

# Rate Limit (可选)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Plain Access Control (明文访问权限有效期，单位：秒，默认600秒=10分钟)
PLAIN_ACCESS_EXPIRY=600

# SMTP 邮件服务 (可选 - 如未配置邮件功能将不可用)
# 用于发送告警邮件、通知邮件等
# 未配置时邮件相关功能将被禁用
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@163.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=Common Management Platform
SMTP_FROM_EMAIL=your-email@163.com

# ============================================
# 阿里云配置 (可选 - 用于短信验证码登录)
# ============================================
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# 短信服务配置
ALIYUN_SMS_SIGN_NAME=Owl平台
ALIYUN_SMS_TEMPLATE_CODE=SMS_000000
ALIYUN_REGION_ID=cn-hangzhou
# 服务类型: onverify (号码认证服务) 或 dysmsapi (普通短信)
ALIYUN_SMS_SERVICE_TYPE=oneverify