{
  "name": "backend",
  "version": "1.0.0",
  "description": "owl管理系统 - 后端",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:init": "npm run db:migrate && npm run db:seed",
    "db:reset": "npm run db:seed:undo && npm run db:migrate:undo && npm run db:migrate && npm run db:seed",
    "db:init:full": "npm run db:reset",
    "db:export": "node scripts/export-dev-data.js",
    "db:generate-seeder": "node scripts/generate-complete-seeder.js",
    "pass": "echo 'admin初始密码：R994wjZIIB，请勿在线上系统中使用该密码。'",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop owl-backend",
    "pm2:restart": "pm2 restart owl-backend",
    "pm2:logs": "pm2 logs owl-backend",
    "pm2:status": "pm2 status",
    "package": "bash scripts/package.sh",
    "test": "jest"
  },
  "keywords": [
    "express",
    "postgresql",
    "sequelize",
    "admin"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@alicloud/pop-core": "^1.9.6",
    "accesscontrol": "^2.2.1",
    "axios": "1.15.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "geoip-lite": "^1.4.10",
    "handlebars": "4.7.9",
    "helmet": "^7.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^7.1.3",
    "mongodb": "^6.21.0",
    "morgan": "^1.10.0",
    "multer": "2.1.1",
    "mysql2": "^3.15.3",
    "node-cron": "^3.0.3",
    "nodemailer": "8.0.5",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "redis": "^4.6.12",
    "sequelize": "6.37.8",
    "sm-crypto": "^0.4.0",
